# ── Gemini Vision (device + part identification) ──────────────────────────────
GEMINI_API_KEY=

# ── Featherless.AI (Llama 3.1 step logic) ─────────────────────────────────────
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# ── ElevenLabs (streaming TTS voice) ──────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Jaseci / AWS Lambda orchestration proxy ───────────────────────────────────
JASECI_LAMBDA_URL=
JASECI_API_KEY=

# ── AWS (S3, DynamoDB, Rekognition) ───────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=fix-it-flow-uploads
DYNAMODB_TABLE_NAME=fix-it-flow-sessions

# ── Next.js public vars (exposed to browser) ──────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
